# Database
DATABASE_URL=postgresql://openconduit:openconduit@localhost:5432/openconduit

# Auth
JWT_SECRET=change-me-to-a-random-64-character-string-in-production

# Server
PORT=3000
HOST=0.0.0.0
PUBLIC_URL=https://openconduit.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# WhatsApp Provider (configure via Settings UI after setup)
# WHATSAPP_PROVIDER=meta
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_SECRET=

# Environment
NODE_ENV=development

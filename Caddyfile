{$PUBLIC_URL:localhost} {
    # API routes
    handle /api/* {
        reverse_proxy api:3000
    }

    # Webhook routes (no auth, must be publicly accessible)
    handle /webhooks/* {
        reverse_proxy api:3000
    }

    # Health check
    handle /health {
        reverse_proxy api:3000
    }

    # Frontend (SPA)
    handle {
        reverse_proxy web:80
    }
}
